    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^11.1.24",
    "@socket.io/cluster-adapter": "^0.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@zip.js/zip.js": "^2.8.26",
    "bcryptjs": "^3.0.3",
