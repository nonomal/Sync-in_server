{
  "name": "@sync-in-server/backend",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "Johan Legrand",
    "email": "johan.legrand@sync-in.com"
  },
  "scripts": {
    "build": "nest build",
    "db:check": "drizzle-kit check --config=src/infrastructure/database/configuration.ts",
    "db:drop": "drizzle-kit drop --config=src/infrastructure/database/configuration.ts",
    "db:generate": "drizzle-kit generate --config=src/infrastructure/database/configuration.ts",
    "db:migrate": "drizzle-kit migrate --config=src/infrastructure/database/configuration.ts",
    "db:pull": "drizzle-kit pull --config=src/infrastructure/database/configuration.ts",
    "db:push": "drizzle-kit push --config=src/infrastructure/database/configuration.ts",
    "db:seed": "ts-node src/infrastructure/database/scripts/seed/main.ts",
    "db:up": "drizzle-kit up --config=src/infrastructure/database/configuration.ts",
    "debug:circular": "madge ../dist/server/main.js --circular",
    "debug:circular:image": "madge ../dist/server/main.js --circular --image ../circular-dependencies.png",
    "format": "prettier --write \\\\\\\"src/**/*.ts\\\\\\\" \\\\\\\"test/**/*.ts\\\\\\\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:staged": "git diff --cached --name-only -z --diff-filter=ACM --relative -- . | grep -zE '^(src|apps|libs|test)/.*\\.ts$' | xargs -0 eslint",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "start": "nest start",
    "start:debug": "NODE_ENV=development nest start --debug --watch",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:prod": "nest build && nest start",
    "test": "NODE_ENV=test vitest run",
    "test:cov": "NODE_ENV=test vitest run --coverage",
    "test:debug": "NODE_ENV=test vitest --inspect-brk --inspect --logHeapUsage --no-file-parallelism",
    "test:e2e": "NODE_ENV=test vitest run --config vitest-e2e.config.mts",
    "test:e2e:cov": "NODE_ENV=test vitest run --config vitest-e2e.config.mts --coverage",
    "test:watch": "NODE_ENV=test vitest"
  },
  "dependencies": {
