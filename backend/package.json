    "deepmerge": "^4.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.8.0",
    "fs-extra": "^11.3.5",
    "html-to-text": "^10.0.0",
    "ipaddr.js": "^2.4.0",
    "js-yaml": "^5.0.0",
    "ldapts": "^8.1.8",
    "mime-types": "^3.0.2",
    "mysql2": "^3.22.4",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.1",
    "openid-client": "^6.8.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "qrcode-generator": "^2.0.4",
    "redis": "^5.12.1",
    "safe-regex2": "^5.1.1",
    "sax": "^1.6.0",
    "sharp": "^0.35.2",
    "socket.io": "^4.8.1",
    "tar": "^7.5.16",
    "tesseract.js": "^7.0.0",
    "text-to-svg": "^3.1.5",
